<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- ===== Pre-call: name + room code entry ===== -->
    <LinearLayout
        android:id="@+id/joinForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOR TWO PEOPLE, ONE SCREEN"
            android:textColor="@color/accent2"
            android:textSize="11sp"
            android:letterSpacing="0.16"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Together"
            android:textColor="@color/text"
            android:textSize="40sp"
            android:fontFamily="serif"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call. Watch. React at the exact same second."
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your name"
            android:textColorHint="@color/muted"
            android:textColor="@color/text"
            android:background="@drawable/field_bg"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Server URL, e.g. https://your-app.up.railway.app"
            android:textColorHint="@color/muted"
            android:textColor="@color/text"
            android:background="@drawable/field_bg"
            android:inputType="textUri"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/roomInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Room code (leave blank to create one)"
            android:textColorHint="@color/muted"
            android:textColor="@color/text"
            android:background="@drawable/field_bg"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/startBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start"
            android:textColor="@color/bg"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary_bg"
            android:elevation="0dp" />

    </LinearLayout>

    <!-- ===== In-call UI (hidden until Start is pressed) ===== -->
    <FrameLayout
        android:id="@+id/callFrame"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/surface"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/remoteRenderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/localRenderer"
            android:layout_width="110dp"
            android:layout_height="150dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp" />

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/screenPreviewRenderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/controlsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/callFrame">

        <ImageButton
            android:id="@+id/micBtn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/ctrl_btn_bg" />

        <ImageButton
            android:id="@+id/cameraBtn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/ctrl_btn_bg" />

        <ImageButton
            android:id="@+id/screenShareBtn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="@drawable/ctrl_btn_bg" />

        <ImageButton
            android:id="@+id/leaveBtn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/ctrl_btn_bg" />

    </LinearLayout>

    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/controlsRow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
