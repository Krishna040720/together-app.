# Dependencies
node_modules/

# Secrets — TURN credentials, ports, etc. are read from env vars at runtime
# (see server.js / config.js) and should never be committed.
.env
.env.*

# User-uploaded video files land here at runtime; don't check them in.
server/uploads/*
!server/uploads/.gitkeep

# SQLite database — holds user accounts (password hashes) and owned-room
# records. Never commit real user data.
server/data/

# Android build output
android/.gradle/
android/**/build/
android/local.properties

# OS/editor cruft
.DS_Store
